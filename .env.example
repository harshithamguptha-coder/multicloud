FLASK_SECRET_KEY=change-me
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/multicloud_integrity?retryWrites=true&w=majority
S3_ACCESS_KEY_ID=your-b2-key-id
S3_SECRET_ACCESS_KEY=your-b2-application-key
S3_REGION=us-east-005
S3_BUCKET_PRIMARY=your-b2-primary-bucket
S3_BUCKET_BACKUP=your-b2-backup-bucket
S3_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
S3_PUBLIC_BASE_URL_PRIMARY=https://f005.backblazeb2.com/file/your-b2-primary-bucket
S3_PUBLIC_BASE_URL_BACKUP=https://f005.backblazeb2.com/file/your-b2-backup-bucket
